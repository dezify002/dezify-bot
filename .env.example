# Bitget API Credentials
# Get these from: https://www.bitget.com/support/articles/360007298154
BITGET_API_KEY=your_api_key_here
BITGET_API_SECRET=your_api_secret_here
BITGET_PASSPHRASE=your_passphrase_here

# Environment: sandbox | live
BITGET_ENV=sandbox

# Trading Mode: backtest | paper | live
TRADING_MODE=paper

# Risk Parameters
MAX_RISK_PER_TRADE=0.01
MAX_CONCURRENT_POSITIONS=6
MAX_DAILY_DRAWDOWN=0.05
MAX_WEEKLY_DRAWDOWN=0.10

# Universe Filters
MIN_VOLUME_24H_USD=5000000
MIN_LISTING_DAYS=90
MAX_SPREAD_BPS=50

# Strategy Parameters
ADX_THRESHOLD=25
EMA_FAST_DAILY=50
EMA_SLOW_DAILY=200
EMA_FAST_4H=21
EMA_SLOW_4H=55
VOLUME_EXPANSION_RATIO=1.5